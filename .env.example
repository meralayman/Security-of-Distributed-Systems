# --- JWT (API) ---
JWT_SECRET=replace-with-long-random-string-for-jwt

# --- API <-> Worker integrity (HMAC on broker messages; same value in api + worker) ---
INTERNAL_SERVICE_TOKEN=replace-with-long-random-string-api-worker-hmac

# --- PostgreSQL (database container + connection string) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=auditdb
# Port on your PC to reach Postgres (pgAdmin). Default 5433 to avoid clashing with a local Postgres on 5432.
# POSTGRES_HOST_PORT=5433
# Optional: full URL (Compose builds default from POSTGRES_* if unset).
# NEVER use localhost:5433 here for API/worker containers — that host port is only for pgAdmin on your PC.
# Inside Compose, hostname must be `postgres`, port `5432`:
# DATABASE_URL=postgresql://app:changeme@postgres:5432/auditdb

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
# AMQP URL used by API + worker (must match broker credentials)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# Queue name (must match API + worker). Default matches assignment example:
# TASK_QUEUE=tasks_queue

# --- Optional bonus (assignment §17) ---
# WORKER_MAX_RETRIES=3
# WORKER_RETRY_DELAY_MS=150
# ENABLE_TASK_DLX=false
# TASK_DLX_EXCHANGE=tasks_dlx
# TASK_DLX_ROUTE=dead
# TASK_DEAD_QUEUE=tasks_dead

# Worker waits for RabbitMQ AMQP (avoids ECONNREFUSED race on compose up)
# RABBIT_CONNECT_RETRIES=60
# RABBIT_CONNECT_DELAY_MS=2000
